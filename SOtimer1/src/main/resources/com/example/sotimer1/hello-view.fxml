<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sotimer1.HelloController"
            prefWidth="650" prefHeight="650"
            style="-fx-background-color: #f5f5f5;">
    
    <!-- Titlu aplicație -->
    <top>
        <VBox alignment="CENTER" style="-fx-padding: 15; -fx-background-color: #2c3e50;">
            <Label text="⏱ Simulare Carusel cu Timere"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Demonstrație planificare cu java.util.Timer"
                   style="-fx-font-size: 12px; -fx-text-fill: #ecf0f1; -fx-padding: 5 0 0 0;"/>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="15" alignment="CENTER" style="-fx-padding: 20;">
            
            <!-- Container pentru artificii și carusel -->
            <StackPane style="-fx-background-color: white; -fx-padding: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 2);">
                <!-- Carusel 280x280 -->
                <ImageView fx:id="caruselView"
                           fitWidth="280" fitHeight="280"
                           preserveRatio="true"/>
                
                <!-- Fireworks 350x350 - poziționat deasupra -->
                <ImageView fx:id="fireworksView"
                           fitWidth="350" fitHeight="350"
                           preserveRatio="true"
                           visible="false"
                           translateY="-80"/>
            </StackPane>
            
            <!-- Timer 1 - Interval Fix -->
            <TitledPane text="🎠 Timer 1 - Interval Fix (scheduleAtFixedRate)" 
                        expanded="true"
                        style="-fx-font-weight: bold;">
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 15;">
                    <Button text="▶️ Start/Stop" 
                            onAction="#startTimer1" 
                            style="-fx-font-size: 14px; -fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"/>
                    <Label fx:id="labelTimer1" 
                           text="În așteptare..." 
                           style="-fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                </HBox>
            </TitledPane>
            
            <!-- Timer 2 - Cu Perioadă -->
            <TitledPane text="🎆 Timer 2 - Oprire După 5 Secunde (schedule + scheduleAtFixedRate)" 
                        expanded="true"
                        style="-fx-font-weight: bold;">
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 15;">
                    <Button text="▶️ Start/Stop" 
                            onAction="#startTimer2" 
                            style="-fx-font-size: 14px; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;"/>
                    <Label fx:id="labelTimer2" 
                           text="În așteptare..." 
                           style="-fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                </HBox>
            </TitledPane>
            
            <!-- Timer 3 - La Oră Specifică -->
            <TitledPane text="🌙 Timer 3 - La Oră Specifică (schedule cu Date)" 
                        expanded="true"
                        style="-fx-font-weight: bold;">
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 15;">
                    <TextField fx:id="timeInput" 
                               promptText="HH:mm (ex: 18:30)" 
                               prefWidth="150"
                               style="-fx-font-size: 14px;"/>
                    <Button text="⏰ Setează Timer" 
                            onAction="#startTimer3" 
                            style="-fx-font-size: 14px; -fx-background-color: #9b59b6; -fx-text-fill: white; -fx-cursor: hand;"/>
                    <Label fx:id="labelTimer3" 
                           text="În așteptare..." 
                           style="-fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                </HBox>
            </TitledPane>
            
        </VBox>
    </center>
    
    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 10; -fx-background-color: #ecf0f1;">
            <Label text="💡 Trei tipuri de timere: interval fix | cu oprire programată | la moment specific"
                   style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>
        </HBox>
    </bottom>
    
</BorderPane>