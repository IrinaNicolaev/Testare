<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sotimer1.HelloController"
            prefWidth="600" prefHeight="500">

    <!-- Titlu aplicație -->
    <top>
        <Label text="⏱ Control Timere"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 15;"/>
    </top>

    <center>
        <VBox spacing="25" alignment="CENTER" style="-fx-padding: 20;">
            
            <!-- Timer 1 -->
            <TitledPane text="Timer 1 - la interval fix" expanded="true">
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10;">
                    <Button text="Start/Stop Timer 1" onAction="#startTimer1" style="-fx-font-size: 14px;"/>
                    <Label fx:id="labelTimer1" text="În așteptare..." style="-fx-font-size: 14px;"/>
                </HBox>
            </TitledPane>

            <!-- Timer 2 -->
            <TitledPane text="Timer 2 - mesaj după 5 secunde" expanded="true">
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10;">
                    <Button text="Start/Stop Timer 2" onAction="#startTimer2" style="-fx-font-size: 14px;"/>
                    <Label fx:id="labelTimer2" text="În așteptare..." style="-fx-font-size: 14px;"/>
                </HBox>
            </TitledPane>

            <!-- Timer 3 -->
            <TitledPane text="Timer 3 - la ora dorită" expanded="true">
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10;">
                    <TextField fx:id="timeInput" promptText="HH:mm" style="-fx-font-size: 14px;"/>
                    <Button text="Setează timer" onAction="#startTimer3" style="-fx-font-size: 14px;"/>
                    <Label fx:id="labelTimer3" text="În așteptare..." style="-fx-font-size: 14px;"/>
                </HBox>
            </TitledPane>




            <!-- Timer 4 -->
            <TitledPane text="Timer 4 - perioadă 3s după 2s delay" expanded="true">
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10;">
                    <Button text="Start/Stop Timer 4" onAction="#startTimer4" style="-fx-font-size: 14px;"/>
                    <Label fx:id="labelTimer4" text="În așteptare..." style="-fx-font-size: 14px;"/>
                </HBox>
            </TitledPane>

        </VBox>
    </center>
</BorderPane>
